{
  "name": "gst-validator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GSTIN format/checksum validation with pluggable live GSTN lookup and risk scoring",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "build:standalone": "node scripts/build-standalone.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.functions.json",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.99.0"
  }
}
